# Application Environment
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-frontend-domain.vercel.app

# MongoDB Configuration (Use MongoDB Atlas for production)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/the_travel_place?retryWrites=true&w=majority
MONGO_TEST_URI=mongodb+srv://username:password@cluster.mongodb.net/ttp_test_db?retryWrites=true&w=majority

# Redis Configuration (Use Redis Cloud or Upstash for production)
REDIS_URL=redis://default:password@host:port

# JWT Secrets and Lifetimes (Generate strong random strings)
JWT_ACCESS_SECRET=your_super_secure_access_secret_min_32_chars
JWT_ACCESS_LIFETIME=15m
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_min_32_chars
JWT_REFRESH_LIFETIME=30d

# Email Service (Nodemailer with App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_FROM=your_email@gmail.com

# SMS Providers (Multi-provider with automatic routing)
# Termii - Nigerian SMS (Cheapest: ₦2.50/SMS)
TERMII_API_KEY=your_termii_api_key_here
TERMII_BASE_URL=https://v3.api.termii.com
TERMII_SENDER_ID=TravelPlace

# Telnyx - International SMS (₦60/SMS vs Twilio's ₦180/SMS)
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_PHONE_NUMBER=+1234567890

# Twilio - Fallback SMS Provider
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Business API
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_API_VERSION=v18.0

# AWS S3 Configuration (File Storage Service)
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_DEFAULT_ACL=private
AWS_S3_SIGNED_URL_EXPIRATION=3600
AWS_S3_MAX_FILE_SIZE=10485760

# Paystack Configuration (Active Payment Service)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# Amadeus XML SOAP API Configuration (Active Flight Service)
AMADEUS_XML_ENDPOINT=your_amadeus_xml_endpoint
AMADEUS_XML_USERNAME=your_amadeus_username
AMADEUS_XML_PASSWORD=your_amadeus_password
AMADEUS_XML_OFFICE_ID=your_amadeus_office_id

# Amadeus REST API Configuration (For Reference Data)
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Ratehawk Hotel API Configuration
RATEHAWK_BASE_URL=https://api.worldota.net
RATEHAWK_API_KEY_ID=your_ratehawk_api_key_id
RATEHAWK_API_ACCESS_TOKEN=your_ratehawk_api_access_token
RATEHAWK_SANDBOX_URL=https://api.worldota.net

# Allianz Travel Insurance API Configuration
ALLIANZ_BASE_URL=https://www.allianz-travel.com