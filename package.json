{
  "name": "the-travel-place-api",
  "version": "1.0.0",
  "description": "Backend API for The Travel Place (TTP) travel agency.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:performance": "jest --testPathPattern=performance",
    "test:load": "node v1/test/performance/loadTest.js",
    "test:stress": "node v1/test/performance/stressTest.js",
    "test:benchmark": "node v1/test/performance/benchmarkTest.js",
    "test:perf-regression": "node v1/test/performance/regressionTest.js",
    "test:perf-all": "node v1/test/performance/runAllTests.js",
    "test:perf-cicd": "node v1/test/performance/cicdIntegration.js",
    "test:perf-baseline": "node v1/test/performance/runAllTests.js --create-baseline",
    "test:perf-light": "node v1/test/performance/runAllTests.js --skip-stress --skip-benchmark",
    "lint": "eslint .",
    "validate-docs": "node scripts/validate-docs.js",
    "validate-docs:save": "node scripts/validate-docs.js --save-report",
    "validate-docs:json": "node scripts/validate-docs.js --format json",
    "validate-docs:quiet": "node scripts/validate-docs.js --quiet",
    "validate-api-docs": "node scripts/validate-api-docs.js",
    "verify-analytics": "node scripts/verify-analytics.js",
    "verify-analytics-models": "node scripts/verify-analytics-models.js"
  },
  "keywords": [
    "Node.js",
    "Express",
    "API",
    "Travel",
    "Insurance",
    "Flights",
    "Hotels",
    "Payments",
    "Authentication",
    "Authorization",
    "MongoDB",
    "Redis",
    "JWT",
    "Zod",
    "OpenAPI",
    "Cloudinary",
    "Queues"
  ],
  "author": "The Travel Place Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cloudinary": "^1.x.x",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "qrcode": "^1.5.4",
    "redis": "^4.6.14",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.2.2",
    "winston": "^3.13.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "0x": "^5.8.0",
    "autocannon": "^7.15.0",
    "clinic": "^13.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
